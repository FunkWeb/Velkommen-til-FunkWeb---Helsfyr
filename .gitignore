# =====================
# Ren'Py Generated Files
# =====================

# Compiled script cache — auto-regenerated by each developer's machine
game/cache/

# Compiled .rpyc files — auto-generated from .rpy source files
# Excluding these prevents binary diff noise; all devs regenerate from source
game/**/*.rpyc
game/**/*.rpybc

# Ren'Py log files — local only, not relevant to other developers
log.txt
errors.txt
traceback.txt

# =====================
# Saves & User Data
# =====================

# Local playtesting saves — developer-specific, never shared
game/saves/

# Persistent data — machine-specific
game/persistent
game/persistent-*

# =====================
# Ren'Py Build Output
# =====================

# Distribution builds — large, fully reproducible from source
*-dists/
*-market/
/tmp/

# =====================
# Raw / Source Assets
# =====================

# Original unprocessed assets — too large for Git, store externally
# (original RAW photos, GIMP/Krita project files, Audacity sessions etc.)
raw_assets/

# =====================
# OS Generated Files
# =====================

.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
*~
.directory

# =====================
# Editor & IDE Files
# =====================

.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# =====================
# Python
# =====================

__pycache__/
*.py[cod]
*.pyo
.env
.venv
env/
venv/

# =====================
# Miscellaneous
# =====================

*.bak
*.tmp
*.swp
